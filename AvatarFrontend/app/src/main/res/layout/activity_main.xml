<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D3D3D3">

    <!-- Layer 1: Base Face/Body -->
    <ImageView
        android:id="@+id/baseImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/base"
        android:scaleType="fitCenter" />

    <!-- Layer 2: Eyes -->
    <ImageView
        android:id="@+id/eyesImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/eyes_neutral"
        android:scaleType="fitCenter" />

    <!-- Layer 3: Mouth -->
    <ImageView
        android:id="@+id/mouthImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/mouth_neutral"
        android:scaleType="fitCenter" />

    <!-- Top-Left Overlay for IP and Status -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:padding="8dp"> <!-- Semi-transparent black background -->

        <TextView
            android:id="@+id/ipTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP: Loading..."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting..."
            android:textColor="#FFBB33"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</FrameLayout>